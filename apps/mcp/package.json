{
  "name": "mcp",
  "type": "module",
  "version": "1.0.0",
  "description": "Hackathon Starter Kit — Manufact MCP server",
  "author": "",
  "license": "MIT",
  "keywords": [
    "mcp",
    "server",
    "starter",
    "tools",
    "resources",
    "prompts",
    "uiresource",
    "ui",
    "react",
    "widgets",
    "mcp-ui",
    "apps-sdk"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "mcp-use build --no-typecheck",
    "dev": "MCP_PORT=3011 mcp-use dev --port 3011",
    "start": "MCP_PORT=3011 mcp-use start --port 3011",
    "deploy": "mcp-use deploy --port 3011",
    "postinstall": "mcp-use generate-types || true"
  },
  "dependencies": {
    "@openai/apps-sdk-ui": "^0.2.1",
    "mcp-use": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "tailwindcss": "^4.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
